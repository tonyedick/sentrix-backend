APP_NAME=Laravel
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost
APP_FRONTEND_URL=http://localhost:3000

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=sqlite
# DB_HOST=127.0.0.1
# DB_PORT=3306
# DB_DATABASE=laravel
# DB_USERNAME=root
# DB_PASSWORD=

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis
REDIS_QUEUE_CONNECTION=default
REDIS_QUEUE=default

# Mobile (Sanctum) token lifetime in minutes. Empty = non-expiring.
# When set, schedule `sanctum:prune-expired` to purge stale tokens.
SANCTUM_EXPIRATION=

# Auth-token lifecycle (dashboard login). Short-lived access token + a rotating
# refresh token exchanged at POST /auth/refresh. Defaults: 60 min / 30 days.
SANCTUM_ACCESS_TTL_MINUTES=60
SANCTUM_REFRESH_TTL_DAYS=30

# SentrixCore (Python AI agent) bridge. The backend proxies chat (SSE) + act to
# Core and accepts inbound /core/events from it.
#  - ENDPOINT: base URL of the running Core service (uvicorn default :8100).
#    Leave empty to disable Core — chat/act then degrade gracefully (offline).
#  - API_KEY: shared secret. MUST equal Core's SENTRIX_CORE_API_KEY; sent/checked
#    as the X-Service-Token header on every call in both directions.
SENTRIX_CORE_ENDPOINT=http://localhost:8100
SENTRIX_CORE_API_KEY=
SENTRIX_CORE_TIMEOUT=30

# Cross-origin: the dashboard's exact origin (production). Local dev also accepts
# any localhost port. e.g. https://app.sentrix.ng
DASHBOARD_URL=

# Safety escalation pipeline (all default on).
SENTRIX_AUTO_EMERGENCY_ON_OVERDUE=true
SENTRIX_AUTO_INCIDENT_FOR_CRITICAL=true
SENTRIX_AUTO_EMERGENCY_ON_LOST_CONTACT=true

# Live location: coalesce position broadcasts to ≤1 per trip per N seconds,
# and treat a trip as dark (lost contact) after N seconds without a fix.
SENTRIX_LOCATION_BROADCAST_COALESCE=2
SENTRIX_LOCATION_STALE_AFTER=300
# Notification channels (comma-separated): mail,database,broadcast (sms/push pluggable).
SENTRIX_NOTIFICATION_CHANNELS=mail,database,broadcast

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=
REVERB_APP_KEY=
REVERB_APP_SECRET=
REVERB_HOST="localhost"
REVERB_PORT=8080
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"
